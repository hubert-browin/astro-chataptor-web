---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import CallbackWidget from '../components/CallbackWidget.astro';
import CookieConsent from '../components/CookieConsent.astro';
import type { Locale } from '../i18n/config';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  slug?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  author?: string;         // <-- NOWE: Przekazywanie autora dla bloga
  noindex?: boolean;       // <-- NOWE: Obsługa tagu noindex
  isLandingPage?: boolean;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const { 
  title, 
  description, 
  lang, 
  slug = '', 
  image, 
  type,
  publishedAt,
  author,                  // <-- ODBIÓR NOWEGO PROPSA
  noindex = false,         // <-- ODBIÓR NOWEGO PROPSA (domyślnie false)
  isLandingPage = false, 
  hideHeader = false, 
  hideFooter = false 
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Chataptor" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <SEOHead 
      title={title}
      description={description}
      lang={lang}
      slug={slug}
      image={image}
      type={type}
      publishedAt={publishedAt}
      author={author}      {/* <-- PRZEKAZANIE DO SEOHead */}
      noindex={noindex}    {/* <-- PRZEKAZANIE DO SEOHead */}
    />

    {/* GLOBALNE STYLE SKALOWANIA */}
    <style is:global>
      /* Default (Mobile): 15px base */
      html {
        font-size: 15px;
      }

      /* Desktop Fluid Scaling */
      @media (min-width: 1024px) {
        html {
          font-size: 11.5px; 
        }
      }

      /* Large Screens */
      @media (min-width: 1536px) {
        html {
          font-size: 13px; 
        }
      }
        
      html { transition: font-size 0.2s ease-out; }
       
      /* Custom Scrollbar */
      .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: rgba(0, 0, 0, 0.1);
        border-radius: 20px;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background-color: rgba(0, 0, 0, 0.2);
      }

      ::selection {
        background-color: #d1fae5;
        color: #064e3b;
      }
    </style>

  <script is:inline>
    // Minimalistyczna funkcja ładowania skryptów na podstawie zgody
    (function() {
      function getC() {
        try { return JSON.parse(localStorage.getItem('cookie_consent')); } catch (e) { return null; }
      }
      function loadAnalytics() {
        if (window.analyticsLoaded) return;
        window.analyticsLoaded = true;
        // Clarity
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "vypq0o7uwg");
        // GA4
        var gs = document.createElement('script'); gs.async = true; gs.src = "https://www.googletagmanager.com/gtag/js?id=G-1BV9YBEBDT"; document.head.appendChild(gs);
        window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} window.gtag = gtag; gtag('js', new Date()); gtag('config', 'G-1BV9YBEBDT');
      }
      function loadFunctional() {
        if (window.functionalLoaded) return;
        window.functionalLoaded = true;
        // Chataptor Widget
        var cs = document.createElement('script');
        cs.src = "https://chataptor.com/widget/quantumchat-widget.umd.js";
        cs.defer = true;
        cs.setAttribute('data-api-url', "https://chataptor.com");
        cs.setAttribute('data-site-id', "chataptor-1769604218");
        cs.setAttribute('data-widget-key', "cGtflAUCFCQ8y72h6ecYf9nKRLxejR-Y");
        cs.setAttribute('data-welcome-message', "Hello! How can I help you today?");
        cs.setAttribute('data-header-title', "Customer Support");
        cs.setAttribute('data-input-placeholder', "Type your message...");
        cs.setAttribute('data-theme', "light");
        cs.setAttribute('data-position', "bottom-right");
        cs.setAttribute('data-primary-color', "#18181B");
        cs.setAttribute('data-translation-enabled', "true");
        cs.setAttribute('data-debug', "false");
        document.head.appendChild(cs);
      }
      function applyC(c) {
        if (!c) return;
        if (c.analytics) loadAnalytics();
        if (c.functional) loadFunctional();
      }
      applyC(getC());
      window.addEventListener('cookie_consent_updated', function(e) { applyC(e.detail); });
    })();
  </script>

  </head>
  <body class="bg-white text-zinc-900 font-sans overflow-x-hidden flex flex-col min-h-screen">
    
    {!hideHeader && <Header lang={lang} isLandingPage={isLandingPage} />}

    <div class="flex-1 w-full">
      <slot />
      <CallbackWidget />
    </div>

    {!hideFooter && <Footer lang={lang} />}
    
    <CookieConsent lang={lang} />
  </body>
</html>