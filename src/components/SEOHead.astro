---
import type { Locale } from '../i18n/config';
import { getAlternateUrls, getCanonicalUrl } from '../utils/i18n';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  slug: string;
  image?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  author?: string; // Dodany opcjonalny autor dla bloga
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  slug,
  image,
  type = 'website',
  publishedAt,
  author = 'Chataptor', // Domyślny autor
  noindex = false,
} = Astro.props;

const cleanDescription = description.replace(/<[^>]*>?/gm, '').trim();

const finalImage = image || `/images/og-default-${lang}.jpg`;

const alternates = getAlternateUrls(slug);
const canonical = getCanonicalUrl(lang, slug);
const fullTitle = `${title}`;

const ogImage = new URL(finalImage, Astro.site).toString();

const siteUrl = Astro.site ? new URL('/', Astro.site).toString() : 'https://chataptor.com/';
const logoUrl = Astro.site ? new URL('/images/landing/logo-black.png', Astro.site).toString() : 'https://chataptor.com/images/landing/logo-black.png';

const localeMap: Record<Locale, string> = {
  en: 'en_US',
  pl: 'pl_PL',
  de: 'de_DE',
  fr: 'fr_FR',
  es: 'es_ES',
  it: 'it_IT',
  cs: 'cs_CZ',
  sk: 'sk_SK',
};

const formattedLocale = localeMap[lang] || 'en_US';

// --- LOGIKA SCHEMA.ORG ---

// 1. Ustalanie dokładnego typu strony
let schemaPageType = 'WebPage';
if (type === 'article') {
  schemaPageType = 'Article';
} else if (slug.includes('about')) {
  schemaPageType = 'AboutPage'; // Wzmocnienie sygnałów E-E-A-T dla zakładki "O nas"
} else if (slug.includes('privacy') || slug.includes('terms')) {
  schemaPageType = 'WebPage'; 
}

// 2. Budowa głównej encji strony
const mainEntity: any = {
  "@type": schemaPageType,
  "@id": `${canonical}#webpage`,
  "name": title,
  "description": cleanDescription,
  "url": canonical,
  "inLanguage": lang,
  "publisher": {
    "@id": `${siteUrl}#organization`
  }
};

// 3. Dodatkowe pola dla artykułów (Blog)
if (type === 'article') {
  mainEntity["author"] = {
    "@type": author === 'Chataptor' ? "Organization" : "Person",
    "name": author
  };
  if (publishedAt) {
    mainEntity["datePublished"] = publishedAt.toISOString();
  }
}

const schemaGraph: any[] = [
  mainEntity,
  {
    "@type": "Organization",
    "@id": `${siteUrl}#organization`,
    "name": "Chataptor",
    "url": siteUrl,
    "logo": logoUrl,
    "sameAs": [
      // "https://twitter.com/chataptor",
      // "https://www.linkedin.com/company/chataptor"
    ]
  }
];

// 4. Wstrzykiwanie SoftwareApplication TYLKO dla strony głównej (Landing Page)
if (slug === '') {
  schemaGraph.push({
    "@type": "SoftwareApplication",
    "@id": `${siteUrl}#software`,
    "name": "Chataptor",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "url": siteUrl,
    "offers": {
      "@type": "Offer",
      "price": "0", // Lub inna domyślna cena/informacja
      "priceCurrency": "USD"
    }
  });
}
---

<title>{fullTitle}</title>
{noindex && <meta name="robots" content="noindex, nofollow" />}
<meta name="description" content={cleanDescription} />
<link rel="canonical" href={canonical} />

{alternates.map((alt) => (
  <link rel="alternate" hreflang={alt.lang} href={alt.url} />
))}
<link
  rel="alternate"
  hreflang="x-default"
  href={alternates.find((a) => a.lang === 'en')?.url}
/>

<meta property="og:site_name" content="Chataptor" />
<meta property="og:title" content={title} />
<meta property="og:description" content={cleanDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={formattedLocale} />
{alternates
  .filter((a) => a.lang !== lang)
  .map((alt) => (
    <meta property="og:locale:alternate" content={localeMap[alt.lang] || alt.lang} />
  ))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@chataptor" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={cleanDescription} />
<meta name="twitter:image" content={ogImage} />

{type === 'article' && publishedAt && (
  <meta property="article:published_time" content={publishedAt.toISOString()} />
)}

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": schemaGraph
})} />