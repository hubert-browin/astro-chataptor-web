---
import type { Locale } from '../i18n/config';
import { getAlternateUrls, getCanonicalUrl } from '../utils/i18n';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  slug: string;
  image?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
}

const {
  title,
  description,
  lang,
  slug,
  image = 'public/images/og-default.jpg',
  type = 'website',
  publishedAt,
} = Astro.props;

const alternates = getAlternateUrls(slug);
const canonical = getCanonicalUrl(lang, slug);
const fullTitle = `${title}`;

// Dynamiczny URL dla obrazka przy użyciu domeny skonfigurowanej w astro.config.mjs
const ogImage = new URL(image, Astro.site).toString();

// Mapowanie locale pod standard Open Graph (np. dla Facebooka)
const localeMap: Record<Locale, string> = {
  en: 'en_US',
  pl: 'pl_PL',
  de: 'de_DE',
  fr: 'fr_FR',
  es: 'es_ES',
  it: 'it_IT',
  cs: 'cs_CZ',
  sk: 'sk_SK',
};

const formattedLocale = localeMap[lang] || 'en_US';
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{alternates.map((alt) => (
  <link rel="alternate" hreflang={alt.lang} href={alt.url} />
))}
<link
  rel="alternate"
  hreflang="x-default"
  href={alternates.find((a) => a.lang === 'en')?.url}
/>

<meta property="og:site_name" content="Chataptor" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={formattedLocale} />
{alternates
  .filter((a) => a.lang !== lang)
  .map((alt) => (
    <meta property="og:locale:alternate" content={localeMap[alt.lang] || alt.lang} />
  ))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{type === 'article' && publishedAt && (
  <meta property="article:published_time" content={publishedAt.toISOString()} />
)}

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": type === 'article' ? 'Article' : 'WebPage',
  "name": title,
  "description": description,
  "url": canonical,
  "inLanguage": lang,
  ...(type === 'article' && publishedAt && {
    "datePublished": publishedAt.toISOString(),
  }),
})} />