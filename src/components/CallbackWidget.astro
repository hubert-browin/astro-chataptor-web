---
// src/components/CallbackWidget.astro
// Minimalistyczny widget kontaktowy w stylu Apple / iOS.
---

<!-- Przycisk wywołujący (Desktop: doczepiony do lewej krawędzi) -->
<button 
  id="callback-trigger" 
  class="hidden md:flex fixed left-0 top-1/2 -translate-y-1/2 -translate-x-3 hover:translate-x-0 z-40 items-center gap-3 bg-white/90 backdrop-blur-md shadow-[4px_0_24px_rgba(0,0,0,0.08)] border border-[#E4E4E7] rounded-r-[20px] pl-5 pr-3 py-2.5 text-[#18181B] transition-all duration-400 ease-[cubic-bezier(0.32,0.72,0,1)] group"
  aria-label="Otwórz formularz kontaktowy"
>
  <span class="text-[14.5px] font-medium tracking-tight">Zostaw numer</span>
  <div class="relative flex items-center justify-center w-8 h-8 bg-[#FAFAFA] rounded-full text-[#18181B] border border-[#E4E4E7]/50 group-hover:bg-[#18181B] group-hover:text-white transition-colors duration-300 shadow-sm">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
    </svg>
    <!-- Subtelny indykator dostępności -->
    <span class="absolute -top-0.5 -right-0.5 flex h-2.5 w-2.5">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#059669] opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#059669] border-2 border-white"></span>
    </span>
  </div>
</button>

<!-- Tło zaciemniające (Backdrop) -->
<div 
  id="callback-backdrop" 
  class="fixed inset-0 z-50 bg-[#18181B]/5 backdrop-blur-[3px] opacity-0 pointer-events-none transition-opacity duration-400 ease-[cubic-bezier(0.32,0.72,0,1)]"
></div>

<!-- Panel Modalny (Desktop: Z lewej | Mobile: Na środku) -->
<div 
  id="callback-panel" 
  class="fixed z-50 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[92%] max-w-[400px] bg-white rounded-[28px] shadow-[0_24px_48px_-12px_rgba(0,0,0,0.18)] opacity-0 scale-[0.92] pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] p-6 md:p-7 border border-[#E4E4E7]/60
         md:left-6 md:-translate-x-[120%] md:opacity-100 md:scale-100"
>
  <!-- Przycisk zamykania -->
  <button 
    id="callback-close" 
    class="absolute top-5 right-5 p-1.5 bg-[#FAFAFA] text-[#71717A] hover:text-[#18181B] hover:bg-[#E4E4E7] rounded-full transition-colors duration-200 z-10"
    aria-label="Zamknij okno"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Nagłówek i awatar -->
  <div class="flex items-center gap-4 mb-7 mt-1">
    <div class="relative shrink-0">
      <img 
        src="/images/about/hubert.webp" 
        alt="Hubert" 
        class="w-[60px] h-[60px] rounded-full object-cover object-top border border-[#E4E4E7] shadow-sm"
        onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'><rect fill=\'%23FAFAFA\' width=\'100\' height=\'100\'/><circle fill=\'%23E4E4E7\' cx=\'50\' cy=\'40\' r=\'20\'/><path fill=\'%23E4E4E7\' d=\'M50 70c-20 0-35 15-35 30h70c0-15-15-30-35-30z\'/></svg>'"
      />
      <div class="absolute bottom-0 right-0 h-4 w-4 bg-[#059669] border-2 border-white rounded-full z-10 shadow-sm"></div>
    </div>
    <div class="pr-6">
      <h3 class="text-[18px] font-semibold text-[#18181B] leading-tight tracking-tight mb-1">Hej, masz chwilę? 👋</h3>
      <p class="text-[#71717A] text-[13.5px] leading-snug">
        Zostaw mi swój numer. Obiecuję oddzwonić w <strong class="font-medium text-[#18181B]">mniej niż 10 minut</strong>!
      </p>
    </div>
  </div>

  <!-- Formularz (W pełni Inline) -->
  <form id="callback-form" class="relative w-full group" novalidate>
    
    <!-- Wrapper na input telefoniczny -->
    <div id="input-wrapper" class="relative flex items-center bg-[#FAFAFA] rounded-[18px] overflow-hidden border border-[#E4E4E7] transition-all duration-300 focus-within:bg-white focus-within:border-[#059669] focus-within:ring-4 focus-within:ring-[#059669]/10 shadow-sm p-1.5">
      
      <!-- Kontener flagi z obrazkiem (zastępuje problematyczne emoji) -->
      <div id="flag-container" class="pl-3 pr-2 py-2 flex items-center justify-center border-r border-[#E4E4E7]/80 select-none shrink-0 min-w-[48px] transition-all duration-300">
        <img 
          id="country-flag" 
          src="https://flagcdn.com/w40/pl.png" 
          alt="Flaga" 
          class="w-6 h-4 object-cover rounded-[3px] shadow-[0_0_0_1px_rgba(0,0,0,0.08)] transition-all duration-300" 
        />
      </div>

      <!-- Właściwe pole input -->
      <input 
        type="tel" 
        id="phone-input"
        inputmode="tel"
        autocomplete="tel"
        placeholder="+48 123 456 789" 
        class="w-full bg-transparent border-none outline-none pl-3 pr-2 py-2.5 text-[#18181B] text-[15px] font-medium placeholder:text-[#A1A1AA] tracking-wide"
      />

      <!-- Przycisk akcji (Inline) -> integruje w sobie weryfikację -->
      <button 
        type="submit" 
        id="submit-btn"
        disabled
        class="shrink-0 w-11 h-11 flex items-center justify-center rounded-[13px] transition-all duration-300 relative overflow-hidden bg-[#E4E4E7] text-[#A1A1AA] cursor-not-allowed"
        aria-label="Wyślij numer"
      >
        <!-- Ikonka strzałki -->
        <svg id="submit-icon" xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        
        <!-- Spinner ładowania -->
        <svg id="submit-spinner" class="absolute h-5 w-5 text-white opacity-0 scale-50 transition-all duration-300 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>

        <!-- Ikonka sukcesu (po wysłaniu) -->
        <svg id="submit-success" xmlns="http://www.w3.org/2000/svg" class="absolute w-[22px] h-[22px] text-white opacity-0 scale-50 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </button>
    </div>
    
    <!-- Subtelny komunikat o sukcesie pod spodem -->
    <div id="success-msg" class="absolute -bottom-7 left-0 right-0 text-center opacity-0 transition-opacity duration-300 pointer-events-none">
      <span class="text-[13px] font-medium tracking-tight text-[#059669] bg-[#059669]/10 px-3 py-1 rounded-full">Numer został wysłany!</span>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const backdrop = document.getElementById('callback-backdrop');
    const panel = document.getElementById('callback-panel');
    const trigger = document.getElementById('callback-trigger');
    const closeBtn = document.getElementById('callback-close');
    
    const form = document.getElementById('callback-form') as HTMLFormElement;
    const phoneInput = document.getElementById('phone-input') as HTMLInputElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    
    const submitIcon = document.getElementById('submit-icon');
    const submitSpinner = document.getElementById('submit-spinner');
    const submitSuccess = document.getElementById('submit-success');
    
    const inputWrapper = document.getElementById('input-wrapper');
    const successMsg = document.getElementById('success-msg');
    const countryFlag = document.getElementById('country-flag') as HTMLImageElement;

    let isSubmitting = false;
    let currentFlagIso = 'pl';

    // Baza kierunkowych z kodami ISO zamiast emoji
    const countryCodes: Record<string, { iso: string, minLength: number, maxLength: number, format?: (num: string) => string }> = {
      '48': { iso: 'pl', minLength: 9, maxLength: 9, format: (n) => n.replace(/(\d{3})(?=\d)/g, '$1 ') }, // Polska
      '49': { iso: 'de', minLength: 10, maxLength: 11 }, // Niemcy
      '44': { iso: 'gb', minLength: 10, maxLength: 10, format: (n) => n.replace(/(\d{4})(\d{6})/, '$1 $2') }, // UK
      '420': { iso: 'cz', minLength: 9, maxLength: 9, format: (n) => n.replace(/(\d{3})(?=\d)/g, '$1 ') }, // Czechy
      '421': { iso: 'sk', minLength: 9, maxLength: 9, format: (n) => n.replace(/(\d{3})(?=\d)/g, '$1 ') }, // Słowacja
      '33': { iso: 'fr', minLength: 9, maxLength: 9, format: (n) => n.replace(/(\d{1})(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5').trim() }, // Francja
      '34': { iso: 'es', minLength: 9, maxLength: 9, format: (n) => n.replace(/(\d{3})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4').trim() }, // Hiszpania
      '39': { iso: 'it', minLength: 9, maxLength: 10 }, // Włochy
      '1': { iso: 'us', minLength: 10, maxLength: 10, format: (n) => n.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3') }, // USA/Kanada
      '380': { iso: 'ua', minLength: 9, maxLength: 9, format: (n) => n.replace(/(\d{2})(\d{3})(\d{2})(\d{2})/, '$1 $2 $3 $4') }, // Ukraina
      'default': { iso: 'globe', minLength: 6, maxLength: 15 } // Fallback
    };

    // Obrazek SVG z globusem (w data URI) do użycia gdy kraj jest nieznany
    const globeSvg = "data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23A1A1AA' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Ccircle cx='12' cy='12' r='10'%3E%3C/circle%3E%3Cline x1='2' y1='12' x2='22' y2='12'%3E%3C/line%3E%3Cpath d='M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z'%3E%3C/path%3E%3C/svg%3E";

    const getFlagUrl = (iso: string) => {
      if (iso === 'globe') return globeSvg;
      return `https://flagcdn.com/w40/${iso}.png`;
    };

    const parsePhoneNumber = (input: string) => {
      let cleaned = input.replace(/[^\d+]/g, '');
      
      if (/^[1-9]/.test(cleaned)) {
        cleaned = '+48' + cleaned;
      }
      if (cleaned.startsWith('00')) {
          cleaned = '+' + cleaned.substring(2);
      }
      if(cleaned.includes('+') && cleaned.indexOf('+') !== 0) {
          cleaned = '+' + cleaned.replace(/\+/g, '');
      }

      let code = '';
      let number = '';
      let countryInfo = countryCodes['default'];
      let foundCode = false;

      if (cleaned.startsWith('+')) {
        const potentialCodeStr = cleaned.substring(1); 
        for (let i = 3; i >= 1; i--) {
          const potentialCode = potentialCodeStr.substring(0, i);
          if (countryCodes[potentialCode]) {
            code = potentialCode;
            number = potentialCodeStr.substring(i);
            countryInfo = countryCodes[potentialCode];
            foundCode = true;
            break;
          }
        }
        
        if (!foundCode && potentialCodeStr.length > 0) {
           let codeLen = 2;
           if(potentialCodeStr.startsWith('1') || potentialCodeStr.startsWith('7')) codeLen = 1; 
           if(potentialCodeStr.startsWith('42') || potentialCodeStr.startsWith('38') || potentialCodeStr.startsWith('37')) codeLen = 3;
           
           code = potentialCodeStr.substring(0, codeLen);
           number = potentialCodeStr.substring(codeLen);
        }
      } else {
        code = '48';
        number = cleaned;
        countryInfo = countryCodes['48'];
      }

      return { raw: cleaned, code: code, number: number, info: countryInfo };
    };

    if (phoneInput) {
      phoneInput.addEventListener('focus', () => {
          if(phoneInput.value === '') {
              phoneInput.value = '+48 ';
              if(countryFlag && currentFlagIso !== 'pl') {
                 currentFlagIso = 'pl';
                 countryFlag.src = getFlagUrl('pl');
              }
          }
      });

      phoneInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const selectionStart = target.selectionStart;
        const oldLength = target.value.length;

        const parsed = parsePhoneNumber(target.value);
        
        // --- AKTUALIZACJA OBRAZKA FLAGI Z PŁYNNĄ ANIMACJĄ ---
        if (countryFlag && parsed.code) {
           if (currentFlagIso !== parsed.info.iso) {
               currentFlagIso = parsed.info.iso;
               countryFlag.style.transform = 'scale(0.8)';
               countryFlag.style.opacity = '0.5';
               setTimeout(() => {
                   countryFlag.src = getFlagUrl(parsed.info.iso);
                   countryFlag.style.transform = 'scale(1)';
                   countryFlag.style.opacity = '1';
               }, 150);
           }
        } else if (countryFlag && !parsed.raw && currentFlagIso !== 'globe') {
            currentFlagIso = 'globe';
            countryFlag.src = globeSvg;
        }

        // --- FORMATOWANIE NUMERU ---
        let displayValue = parsed.raw.startsWith('+') ? '+' + parsed.code : '';
        if (displayValue) displayValue += ' ';

        if (parsed.number) {
            if (parsed.info.format) {
                let formattedNum = parsed.info.format(parsed.number);
                displayValue += formattedNum;
            } else {
                let formatted = parsed.number.replace(/\s/g, ''); 
                displayValue += formatted;
            }
        }
        
        const maxLenWithoutSpaces = parsed.info.maxLength;
        const currentNumLen = parsed.number.replace(/\s/g, '').length;
        
        if (currentNumLen > maxLenWithoutSpaces) {
             target.value = displayValue.substring(0, displayValue.length - 1);
        } else {
             target.value = displayValue;
        }

        if (selectionStart !== null && target.value.length !== oldLength) {
             const diff = target.value.length - oldLength;
             target.setSelectionRange(selectionStart + diff, selectionStart + diff);
        }

        // --- WALIDACJA ---
        const isValid = parsed.number.replace(/\s/g, '').length >= parsed.info.minLength && 
                        parsed.number.replace(/\s/g, '').length <= parsed.info.maxLength &&
                        parsed.code.length > 0;
        
        if (isValid) {
          submitBtn.disabled = false;
          submitBtn.classList.remove('bg-[#E4E4E7]', 'text-[#A1A1AA]', 'cursor-not-allowed');
          submitBtn.classList.add('bg-[#059669]', 'hover:bg-[#047857]', 'text-white', 'cursor-pointer', 'shadow-[0_4px_12px_rgba(5,150,105,0.25)]', 'hover:-translate-y-[1px]', 'active:translate-y-[1px]', 'active:scale-95');
          submitIcon?.classList.add('translate-x-[2px]');
          inputWrapper?.classList.add('ring-4', 'ring-[#059669]/15', 'border-[#059669]');
        } else {
          submitBtn.disabled = true;
          submitBtn.classList.add('bg-[#E4E4E7]', 'text-[#A1A1AA]', 'cursor-not-allowed');
          submitBtn.classList.remove('bg-[#059669]', 'hover:bg-[#047857]', 'text-white', 'cursor-pointer', 'shadow-[0_4px_12px_rgba(5,150,105,0.25)]', 'hover:-translate-y-[1px]', 'active:translate-y-[1px]', 'active:scale-95');
          submitIcon?.classList.remove('translate-x-[2px]');
          inputWrapper?.classList.remove('ring-4', 'ring-[#059669]/15', 'border-[#059669]');
        }
      });
    }

    // --- LOGIKA OBSŁUGI FORMULARZA ---
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      if (submitBtn.disabled || isSubmitting) return;

      const phoneNumber = phoneInput.value.replace(/\s/g, '');
      console.log('Wysyłanie numeru:', phoneNumber); 

      isSubmitting = true;
      submitBtn.disabled = true;
      phoneInput.disabled = true;

      submitIcon?.classList.add('opacity-0', 'scale-0', 'hidden');
      submitSpinner?.classList.remove('opacity-0', 'scale-50', 'hidden');
      submitSpinner?.classList.add('opacity-100', 'scale-100');

      setTimeout(() => {
        submitSpinner?.classList.add('opacity-0', 'scale-50', 'hidden');
        submitSpinner?.classList.remove('opacity-100', 'scale-100');
        
        submitSuccess?.classList.remove('opacity-0', 'scale-50');
        submitSuccess?.classList.add('opacity-100', 'scale-100');
        
        successMsg?.classList.remove('opacity-0');

        setTimeout(() => {
          closeModal();
          setTimeout(resetForm, 500); 
        }, 1800);

      }, 1200);
    });

    const resetForm = () => {
      if (!phoneInput || !form) return;
      form.reset();
      phoneInput.value = ''; 
      
      // Reset do polskiej flagi
      if(countryFlag) {
          currentFlagIso = 'pl';
          countryFlag.src = getFlagUrl('pl');
      }

      phoneInput.disabled = false;
      isSubmitting = false;
      
      submitIcon?.classList.remove('opacity-0', 'scale-0', 'hidden', 'translate-x-[2px]');
      submitSpinner?.classList.add('opacity-0', 'scale-50');
      submitSpinner?.classList.remove('hidden'); 
      submitSuccess?.classList.add('opacity-0', 'scale-50');
      
      submitBtn.disabled = true;
      submitBtn.classList.add('bg-[#E4E4E7]', 'text-[#A1A1AA]', 'cursor-not-allowed');
      submitBtn.classList.remove('bg-[#059669]', 'hover:bg-[#047857]', 'text-white', 'cursor-pointer', 'shadow-[0_4px_12px_rgba(5,150,105,0.25)]', 'hover:-translate-y-[1px]', 'active:translate-y-[1px]', 'active:scale-95');
      
      inputWrapper?.classList.remove('ring-4', 'ring-[#059669]/15', 'border-[#059669]');
      successMsg?.classList.add('opacity-0');
    };

    // --- LOGIKA OKIENKA (MODAL / SLIDER) ---
    const openModal = () => {
      if (!backdrop || !panel) return;
      
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100', 'pointer-events-auto');
      
      panel.classList.remove('opacity-0', 'scale-[0.92]', 'pointer-events-none');
      panel.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
      
      panel.classList.remove('md:-translate-x-[120%]');
      panel.classList.add('md:-translate-x-0');
      
      setTimeout(() => phoneInput?.focus(), 400);
    };

    const closeModal = () => {
      if (!backdrop || !panel) return;
      
      backdrop.classList.remove('opacity-100', 'pointer-events-auto');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      
      panel.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
      panel.classList.add('opacity-0', 'scale-[0.92]', 'pointer-events-none');
      
      panel.classList.remove('md:-translate-x-0');
      panel.classList.add('md:-translate-x-[120%]');
      
      sessionStorage.setItem('callback_shown', 'true');
    };

    trigger?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    const isMobile = window.innerWidth < 768;
    const hasBeenShown = sessionStorage.getItem('callback_shown');

    if (isMobile && !hasBeenShown) {
      setTimeout(() => {
        openModal();
      }, 10000); 
    }
  });
</script>