---

<div id="cookie-consent-container" class="fixed bottom-0 left-0 w-full md:bottom-4 md:left-4 md:w-[400px] bg-white border border-zinc-200 p-5 z-[99999] text-sm hidden font-sans text-zinc-900 md:rounded-2xl" style="box-shadow: none;">
  
  <div id="cookie-banner" class="flex flex-col gap-4">
    <p class="text-zinc-800 leading-relaxed m-0 text-xs sm:text-sm text-justify">
      {t.bannerText}
    </p>
    <div class="flex flex-wrap gap-2 items-center">
      <button id="btn-accept-all" class="flex-1 bg-emerald-600 text-white rounded-full px-3 py-2 text-xs font-semibold hover:bg-emerald-500 transition-all hover:scale-[1.02] shadow-sm shadow-emerald-600/10 active:scale-95 text-center">
        {t.acceptAll}
      </button>
      <button id="btn-reject-all" class="flex-1 bg-white text-zinc-900 border border-zinc-200 rounded-full px-3 py-2 text-xs font-medium hover:bg-zinc-50 transition-colors text-center">
        {t.rejectAll}
      </button>
      <button id="btn-customize" class="w-full sm:w-auto bg-transparent text-zinc-500 underline text-xs font-medium px-2 py-2 hover:text-zinc-800 transition-colors text-center rounded-full">
        {t.customize}
      </button>
    </div>
  </div>

  <div id="cookie-customize" class="hidden flex-col gap-4">
    <h3 class="font-semibold text-zinc-900 text-sm m-0">{t.customize}</h3>
    
    <div class="flex flex-col gap-3 max-h-[50vh] overflow-y-auto custom-scrollbar pr-2">
      <!-- Necessary -->
      <label class="flex items-start gap-3 cursor-not-allowed opacity-80">
        <input type="checkbox" checked disabled class="mt-1 w-4 h-4 text-emerald-600 bg-zinc-100 border-zinc-300 rounded focus:ring-emerald-600 disabled:opacity-50" />
        <div class="flex-1">
          <span class="block font-medium text-zinc-900 mb-1 leading-none text-xs">{t.necessary}</span>
          <span class="block text-[11px] text-zinc-500 leading-relaxed">{t.necessaryDesc}</span>
        </div>
      </label>

      <!-- Analytics -->
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" id="toggle-analytics" class="mt-1 w-4 h-4 text-emerald-600 bg-zinc-100 border-zinc-300 rounded focus:ring-emerald-600" />
        <div class="flex-1">
          <span class="block font-medium text-zinc-900 mb-1 leading-none text-xs">{t.analytics}</span>
          <span class="block text-[11px] text-zinc-500 leading-relaxed">{t.analyticsDesc}</span>
        </div>
      </label>

      <!-- Functional -->
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" id="toggle-functional" class="mt-1 w-4 h-4 text-emerald-600 bg-zinc-100 border-zinc-300 rounded focus:ring-emerald-600" />
        <div class="flex-1">
          <span class="block font-medium text-zinc-900 mb-1 leading-none text-xs">{t.functional}</span>
          <span class="block text-[11px] text-zinc-500 leading-relaxed">{t.functionalDesc}</span>
        </div>
      </label>

      <!-- Marketing -->
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" id="toggle-marketing" class="mt-1 w-4 h-4 text-emerald-600 bg-zinc-100 border-zinc-300 rounded focus:ring-emerald-600" />
        <div class="flex-1">
          <span class="block font-medium text-zinc-900 mb-1 leading-none text-xs">{t.marketing}</span>
          <span class="block text-[11px] text-zinc-500 leading-relaxed">{t.marketingDesc}</span>
        </div>
      </label>
    </div>

    <button id="btn-save-preferences" class="w-full bg-emerald-600 text-white rounded-full px-3 py-2 text-xs font-semibold hover:bg-emerald-500 transition-all hover:scale-[1.02] shadow-sm shadow-emerald-600/10 active:scale-95 mt-2 text-center">
      {t.save}
    </button>
  </div>
</div>

<script>
  (() => {
    const CONSENT_KEY = 'cookie_consent';
    const container = document.getElementById('cookie-consent-container');
    const banner = document.getElementById('cookie-banner');
    const customizePanel = document.getElementById('cookie-customize');
    
    const btnAcceptAll = document.getElementById('btn-accept-all');
    const btnRejectAll = document.getElementById('btn-reject-all');
    const btnCustomize = document.getElementById('btn-customize');
    const btnSave = document.getElementById('btn-save-preferences');

    const toggleAnalytics = document.getElementById('toggle-analytics') as HTMLInputElement;
    const toggleFunctional = document.getElementById('toggle-functional') as HTMLInputElement;
    const toggleMarketing = document.getElementById('toggle-marketing') as HTMLInputElement;

    function getConsent() {
      try {
        const item = localStorage.getItem(CONSENT_KEY);
        return item ? JSON.parse(item) : null;
      } catch (e) {
        return null;
      }
    }

    function saveConsent(preferences: { analytics: boolean; functional: boolean; marketing: boolean }) {
      const data = {
        ...preferences,
        necessary: true,
        timestamp: new Date().getTime()
      };
      localStorage.setItem(CONSENT_KEY, JSON.stringify(data));
      hideBanner();
      window.dispatchEvent(new CustomEvent('cookie_consent_updated', { detail: data }));
    }

    function hideBanner() {
      if (container) {
        container.classList.add('hidden');
      }
    }

    function showBanner() {
      if (container) {
        container.classList.remove('hidden');
      }
    }

    const existingConsent = getConsent();
    if (!existingConsent) {
      showBanner();
    }

    if (btnAcceptAll) {
      btnAcceptAll.addEventListener('click', () => {
        saveConsent({ analytics: true, functional: true, marketing: true });
      });
    }

    if (btnRejectAll) {
      btnRejectAll.addEventListener('click', () => {
        saveConsent({ analytics: false, functional: false, marketing: false });
      });
    }

    if (btnCustomize && banner && customizePanel) {
      btnCustomize.addEventListener('click', () => {
        banner.classList.add('hidden');
        customizePanel.classList.remove('hidden');
        customizePanel.classList.add('flex');
      });
    }

    if (btnSave) {
      btnSave.addEventListener('click', () => {
        saveConsent({
          analytics: toggleAnalytics?.checked || false,
          functional: toggleFunctional?.checked || false,
          marketing: toggleMarketing?.checked || false,
        });
      });
    }
  })();
</script>
