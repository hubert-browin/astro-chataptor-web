---
import { locales, type Locale } from '../../i18n/config';
import { getLanding } from '../../i18n/landing';
import { getAbout } from '../../i18n/about';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getLanding(lang); // For Pricing, Footer, Modal
const tAbout = getAbout(lang); // For About page content

// Ścieżki do zdjęć
const hubertImg = "/images/about/hubert.webp";
const marekImg = "/images/about/marek.webp";
---

<BaseLayout
  title={`${tAbout.hero.title} | Chataptor`}
  description={tAbout.hero.subtitle}
  lang={lang}
  slug="about"
>
  <main class="bg-white selection:bg-emerald-500 selection:text-white">
    
    <section class="relative pt-32 pb-20 md:pt-48 md:pb-28 w-[95%] md:max-w-[72rem] mx-auto overflow-hidden">
      <div class="absolute top-0 right-[5%] w-[1px] h-full bg-zinc-100 hidden md:block"></div>
      <div class="absolute top-0 right-[25%] w-[1px] h-full bg-zinc-100 hidden md:block"></div>
      
      <div class="relative z-10 max-w-5xl">
        <h1 class="text-5xl md:text-6xl lg:text-[5.2rem] font-extrabold tracking-tighter text-zinc-900 leading-[1.05]">
          {tAbout.hero.title}<span class="text-zinc-300">{tAbout.hero.highlight}<span class="text-emerald-500">.</span></span>
        </h1>
        <p class="text-xl md:text-2xl font-medium text-zinc-400 mt-6 tracking-tight">
          {tAbout.hero.subtitle}
        </p>
      </div>
    </section>

    <section class="w-[95%] md:max-w-[72rem] mx-auto border-t border-zinc-200 py-20 md:py-28">
      <div class="max-w-5xl text-lg md:text-xl text-zinc-600 space-y-8 leading-relaxed font-medium">
        <p>
          {tAbout.story.part1} <strong class="text-zinc-900 font-bold text-emerald-900 bg-emerald-50 px-2 py-1">{tAbout.story.highlight}</strong>
        </p>
        <p>
          {tAbout.story.part2}
        </p>
      </div>
    </section>

    <section class="w-[95%] md:max-w-[72rem] mx-auto pb-24 md:pb-32">
      <div class="grid md:grid-cols-3 gap-10 md:gap-12">
        <div class="border-t-2 border-zinc-200 hover:border-emerald-500 pt-8 group transition-colors duration-500">
          <div class="text-5xl md:text-6xl font-extrabold text-zinc-100 mb-6 group-hover:text-emerald-500 transition-colors duration-500 tracking-tighter">01</div>
          <h3 class="text-xl md:text-2xl font-bold text-zinc-900 mb-3 pr-4 leading-tight">{tAbout.problems.p1.title}</h3>
          <p class="text-zinc-500 text-base md:text-lg leading-relaxed">{tAbout.problems.p1.desc}</p>
        </div>
        <div class="border-t-2 border-zinc-200 hover:border-emerald-500 pt-8 group transition-colors duration-500">
          <div class="text-5xl md:text-6xl font-extrabold text-zinc-100 mb-6 group-hover:text-emerald-500 transition-colors duration-500 tracking-tighter">02</div>
          <h3 class="text-xl md:text-2xl font-bold text-zinc-900 mb-3 pr-4 leading-tight">{tAbout.problems.p2.title}</h3>
          <p class="text-zinc-500 text-base md:text-lg leading-relaxed">{tAbout.problems.p2.desc}</p>
        </div>
        <div class="border-t-2 border-zinc-200 hover:border-emerald-500 pt-8 group transition-colors duration-500">
          <div class="text-5xl md:text-6xl font-extrabold text-zinc-100 mb-6 group-hover:text-emerald-500 transition-colors duration-500 tracking-tighter">03</div>
          <h3 class="text-xl md:text-2xl font-bold text-zinc-900 mb-3 pr-4 leading-tight">{tAbout.problems.p3.title}</h3>
          <p class="text-zinc-500 text-base md:text-lg leading-relaxed">{tAbout.problems.p3.desc}</p>
        </div>
      </div>
      
      <div class="mt-20 md:mt-24 max-w-4xl text-xl md:text-3xl font-medium text-zinc-900 leading-snug tracking-tight">
        {tAbout.solution.text} <span class="block mt-4 text-emerald-600">{tAbout.solution.highlight}</span>
      </div>
    </section>

    <section class="bg-zinc-50 py-24 md:py-32 border-y border-zinc-200">
      <div class="w-[95%] md:max-w-[72rem] mx-auto">
        <div class="mb-20 md:mb-28 max-w-4xl">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-zinc-900 tracking-tighter mb-6 leading-[1.05]">
            {tAbout.team.title.replace('.', '')}<span class="text-emerald-500">.</span>
          </h2>
          <p class="text-lg md:text-xl text-zinc-500 leading-relaxed font-medium">
            {tAbout.team.desc}
          </p>
        </div>

        <div class="space-y-20 md:space-y-24">
          <div class="flex flex-col md:flex-row gap-8 md:gap-16 items-start">
            <div class="w-full md:w-1/3 relative group shrink-0">
              <div class="aspect-square md:aspect-[4/5] overflow-hidden bg-zinc-200 rounded-2xl relative shadow-sm ring-1 ring-black/5">
                <img 
                  src={hubertImg} 
                  alt="Hubert" 
                  class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-in-out mix-blend-multiply group-hover:scale-105"
                />
              </div>
            </div>
            <div class="w-full md:w-2/3 md:pt-4">
              <h3 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-2 tracking-tight">Hubert</h3>
              <p class="text-xs font-bold text-emerald-600 uppercase tracking-widest mb-6">{tAbout.team.hubert.role}</p>
              <p class="text-zinc-500 leading-relaxed text-base md:text-lg">
                {tAbout.team.hubert.bio}
              </p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row-reverse gap-8 md:gap-16 items-start">
            <div class="w-full md:w-1/3 relative group shrink-0">
              <div class="aspect-square md:aspect-[4/5] overflow-hidden bg-zinc-200 rounded-2xl relative shadow-sm ring-1 ring-black/5">
                <img 
                  src={marekImg} 
                  alt="Marek" 
                  class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-in-out mix-blend-multiply group-hover:scale-105"
                />
              </div>
            </div>
            <div class="w-full md:w-2/3 md:pt-4 md:text-right">
              <h3 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-2 tracking-tight">Marek</h3>
              <p class="text-xs font-bold text-emerald-600 uppercase tracking-widest mb-6">{tAbout.team.marek.role}</p>
              <p class="text-zinc-500 leading-relaxed text-base md:text-lg">
                {tAbout.team.marek.bio}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-zinc-900 text-zinc-400 py-24 md:py-32 flex justify-center w-full">
      <div class="w-[95%] md:max-w-[72rem] grid md:grid-cols-2 gap-16 md:gap-24">
        
        <div class="pr-0 md:pr-8">
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tighter mb-8 leading-tight">
            {tAbout.philosophy.title1.replace('.', '')}<span class="text-emerald-500">.</span>
          </h2>
          <div class="space-y-6 text-lg md:text-xl leading-relaxed">
            <p>
              {tAbout.philosophy.p1}
            </p>
            <p>
              {tAbout.philosophy.p2}
            </p>
          </div>
        </div>

        <div class="md:border-l border-zinc-800 pt-10 md:pt-0 pl-0 md:pl-16 flex flex-col justify-center">
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tighter mb-8 leading-tight">
            {tAbout.philosophy.title2.replace('.', '')}<span class="text-emerald-500">.</span>
          </h2>
          <div class="space-y-6 text-lg md:text-xl leading-relaxed">
            <p>
              {tAbout.philosophy.p3}
            </p>
            <p>
              {tAbout.philosophy.p4}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="pricing" class="py-16 md:py-24 lg:py-32 px-4 md:px-6 w-[95%] md:max-w-[72rem] mx-auto">
      <div class="text-center mb-12 lg:mb-16 xl:mb-24">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-zinc-900 mb-6 tracking-tight">{tAbout.cta.title}</h2>
        <p class="text-lg text-zinc-500 max-w-2xl mx-auto">{tAbout.cta.desc}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-zinc-50 rounded-[2.5rem] p-8 ring-1 ring-black/5 hover:shadow-xl transition-all relative flex flex-col">
          <div class="mb-4">
            <h3 class="text-xl font-bold text-zinc-900">{t.pricing.starter.title}</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-zinc-900">{t.pricing.starter.price}</span>
              <span class="text-zinc-500">{t.pricing.starter.period}</span>
            </div>
            <p class="text-sm text-zinc-500 mt-2">{t.pricing.starter.desc}</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.starter.features.realtime}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.starter.features.ai}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.starter.features.languages}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.starter.features.omnichannel}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.starter.features.marketing}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600 pt-2 border-t border-zinc-200 mt-2">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.starter.features.limit}</span>
            </li>
          </ul>
          <a href="/register" class="w-full block text-center py-3 rounded-xl bg-white border border-zinc-200 text-zinc-900 font-bold hover:bg-zinc-50 transition-colors shadow-sm">{t.pricing.starter.cta}</a>
        </div>

        <div class="bg-zinc-900 text-white rounded-[2.5rem] p-8 ring-1 ring-black/5 hover:shadow-2xl transition-all relative flex flex-col transform md:-translate-y-4">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">{t.pricing.plus.badge}</div>
          <div class="mb-4">
            <h3 class="text-xl font-bold text-white">{t.pricing.plus.title}</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-white">{t.pricing.plus.price}</span>
              <span class="text-zinc-400">{t.pricing.plus.period}</span>
            </div>
            <p class="text-sm text-zinc-400 mt-2">{t.pricing.plus.desc}</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-zinc-300">
              <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="font-bold text-white">{t.pricing.plus.features.allStarter}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-300">
              <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.plus.features.priority}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-300">
              <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.plus.features.analytics}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-300">
              <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.plus.features.onboarding}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-300 pt-2 border-t border-white/10 mt-2">
              <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.plus.features.limit}</span>
            </li>
          </ul>
          <a href="/register?plan=plus" class="w-full block text-center py-3 rounded-xl bg-emerald-500 text-white font-bold hover:bg-emerald-400 transition-colors shadow-lg shadow-emerald-900/20">{t.pricing.plus.cta}</a>
        </div>

        <div class="bg-white rounded-[2.5rem] p-8 ring-1 ring-zinc-200 hover:shadow-xl transition-all relative flex flex-col">
          <div class="mb-4">
            <h3 class="text-xl font-bold text-zinc-900">{t.pricing.unlimited.title}</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-3xl font-bold text-zinc-900">{t.pricing.unlimited.price}</span>
            </div>
            <p class="text-sm text-zinc-500 mt-2">{t.pricing.unlimited.desc}</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.unlimited.features.allFeatures}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.unlimited.features.unlimitedMsgs}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.unlimited.features.guardian}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.unlimited.features.customImpl}</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-zinc-600">
              <svg class="w-5 h-5 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span>{t.pricing.unlimited.features.sla}</span>
            </li>
          </ul>
          
          <div class="relative w-full">
            <button 
              class="modal-trigger cursor-pointer w-full block text-center py-3 rounded-xl bg-white border border-zinc-200 text-zinc-900 font-bold hover:bg-zinc-50 transition-colors shadow-sm active:scale-95"
            >
              {t.pricing.unlimited.cta}
            </button>
          </div>
        </div>
      </div>
    </section>

    <div id="contact-modal" class="contact-modal fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 pointer-events-none">
        <div class="modal-backdrop absolute inset-0 bg-zinc-900/40 backdrop-blur-sm modal-close-btn opacity-0 transition-opacity duration-300"></div>
        
        <div class="modal-content relative w-full max-w-[420px] bg-white/95 backdrop-blur-xl rounded-[2rem] shadow-[0_25px_60px_-10px_rgba(0,0,0,0.15),0_10px_20px_-5px_rgba(0,0,0,0.1)] ring-1 ring-zinc-900/5 p-2 flex flex-col text-left overflow-hidden scale-95 opacity-0 transition-all duration-300">
          
          <button class="modal-close-btn absolute top-3 right-3 p-2 text-zinc-400 hover:text-zinc-700 z-20 bg-zinc-100/50 hover:bg-zinc-100 rounded-full transition-colors active:scale-90">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>

          <div class="px-4 pb-2 pt-3 border-b border-zinc-100/80 mb-1 relative z-10 flex justify-between items-center">
              <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-widest">{t.contactPopup.title}</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 p-1 max-h-[70vh] overflow-y-auto custom-scrollbar">
              <div class="relative group/item sm:col-span-1">
                  <a href="tel:+48695151096" class="flex items-center gap-3 p-3 rounded-xl bg-zinc-50/50 hover:bg-zinc-50 border border-zinc-100/50 hover:border-zinc-200 transition-all h-full">
                      <div class="w-8 h-8 rounded-full bg-white ring-1 ring-zinc-200 flex items-center justify-center text-zinc-600 group-hover/item:bg-zinc-900 group-hover/item:text-white transition-colors shrink-0 shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="text-xs font-bold text-zinc-900">{t.contactPopup.call}</div>
                        <div class="text-[11px] text-zinc-500 font-medium truncate transition-colors">+48 695 151 096</div>
                      </div>
                  </a>
                  <button class="absolute top-2 right-2 p-1.5 text-zinc-300 hover:text-zinc-600 rounded-md hover:bg-zinc-200/50 transition-all copy-btn opacity-0 group-hover/item:opacity-100 z-10" data-text="+48 695 151 096" title={t.contactPopup.copyNumber}>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                  </button>
              </div>

              <div class="relative group/item sm:col-span-1">
                  <a href="mailto:contact@chataptor.com" class="flex items-center gap-3 p-3 rounded-xl bg-zinc-50/50 hover:bg-zinc-50 border border-zinc-100/50 hover:border-zinc-200 transition-all h-full" title="contact@chataptor.com">
                      <div class="w-8 h-8 rounded-full bg-white ring-1 ring-zinc-200 flex items-center justify-center text-zinc-600 group-hover/item:bg-zinc-900 group-hover/item:text-white transition-colors shrink-0 shadow-sm">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                      </div>
                      <div class="min-w-0 flex-1">
                          <div class="text-xs font-bold text-zinc-900">{t.contactPopup.email}</div>
                          <div class="text-[11px] text-zinc-500 font-medium truncate transition-colors">contact@chataptor.com</div>
                      </div>
                  </a>
                  <button class="absolute top-2 right-2 p-1.5 text-zinc-300 hover:text-zinc-600 rounded-md hover:bg-zinc-200/50 transition-all copy-btn opacity-0 group-hover/item:opacity-100 z-10" data-text="contact@chataptor.com" title={t.contactPopup.copyEmail}>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                  </button>
